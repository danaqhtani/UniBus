@model UniBus.Models.ProfileViewModel
@{
    ViewBag.Title = "Profile";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Profile - UniBus</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6c45af",
                        primaryContainer: "#b78efe",
                        secondary: "#b40953",
                        background: "#f6f6f8",
                        surface: "#ffffff",
                        surfaceLow: "#f0f1f3",
                        surfaceHigh: "#e1e2e5",
                        textMain: "#2d2f31",
                        textMuted: "#5a5c5d",
                        outline: "#757779",
                        outlineVariant: "#acadaf"
                    },
                    fontFamily: {
                        headline: ["Manrope", "sans-serif"],
                        body: ["Manrope", "sans-serif"],
                        label: ["Plus Jakarta Sans", "sans-serif"]
                    },
                    borderRadius: {
                        xl: "1.5rem",
                        full: "9999px"
                    }
                }
            }
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .primary-gradient {
            background: linear-gradient(135deg, #6c45af 0%, #b78efe 100%);
        }

        body {
            background-color: #f6f6f8;
            color: #2d2f31;
        }
    </style>
</head>
<body class="font-body min-h-screen bg-background text-textMain">

    <!-- Top Nav -->
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-[0_12px_24px_rgba(108,69,175,0.08)]">
        <div class="flex justify-between items-center px-6 h-16 w-full max-w-7xl mx-auto">
            <div class="flex items-center gap-4">
                <a href="/Home/Index" class="p-2 hover:bg-violet-50 transition-colors rounded-full cursor-pointer">
                </a>

                <a href="/Home/Index" class="text-2xl font-black text-violet-700 font-headline tracking-tight">
                    UniBus
                </a>
            </div>

            <img src="@Url.Content("~/Content/images/register-side.jpg")"
                 alt="logo"
                 class="h-11 w-15 rounded-full object-cover border-2 border-violet-100 shadow-sm" />

            <div class="flex items-center gap-3">
                <!-- Logout button -->
                <a href="/Account/Logout"
                   class="inline-flex items-center justify-center rounded-2xl bg-rose-50 px-4 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100 transition">
                    Logout
                </a>
                <div class="h-10 w-10 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center font-bold">
                    @(string.IsNullOrWhiteSpace(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                </div>
            </div>
        </div>
    </nav>

    <main class="pt-24 pb-32 px-6 max-w-5xl mx-auto">

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                @ViewBag.ErrorMessage
            </div>
        }

        <!-- Header -->
        <header class="mb-10">
            <h1 class="text-4xl font-extrabold font-headline tracking-tight mb-2">Profile</h1>
            <p class="text-textMuted font-medium">Your student account information</p>
        </header>

        <!-- Main Profile Card -->
        <section class="mb-8">
            <div class="bg-white rounded-xl p-6 md:p-8 shadow-[0_12px_24px_rgba(108,69,175,0.08)] border border-slate-200/60">
                <div class="flex flex-col md:flex-row md:items-center gap-6">
                    <div class="h-24 w-24 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center text-3xl font-black shrink-0">
                        @(string.IsNullOrWhiteSpace(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                    </div>

                    <div class="flex-1">
                        <p class="text-xs font-bold font-label uppercase tracking-widest text-slate-500 mb-2">
                            Student Profile
                        </p>

                        <h2 class="text-3xl font-bold font-headline text-slate-900">
                            @Model.FullName
                        </h2>

                        <p class="text-slate-500 mt-1">
                            @@@Model.Username
                        </p>
                    </div>

                    <div class="bg-slate-50 rounded-2xl px-4 py-3 min-w-[130px]">
                        <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1">
                            Student ID
                        </p>
                        <p class="font-bold text-slate-900">
                            @Model.StudentId
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Info Grid -->
        <section>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">Full Name</p>
                    <p class="text-lg font-bold text-slate-900">@Model.FullName</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">Username</p>
                    <p class="text-lg font-bold text-slate-900">@Model.Username</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">University Email</p>
                    <p class="text-lg font-bold text-slate-900 break-all">@Model.UniversityEmail</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">Phone Number</p>
                    <p class="text-lg font-bold text-slate-900">@Model.PhoneNumber</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">Campus</p>
                    <p class="text-lg font-bold text-slate-900">@Model.CampusLabel</p>

                    @*
                        REAL DATABASE LATER:
                        Campus name should come directly from Building table
                        instead of manual mapping in controller.
                    *@
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">Building ID</p>
                    <p class="text-lg font-bold text-slate-900">@Model.BuildingId</p>
                </div>
            </div>
        </section>
    </main>

    <!-- Bottom Navigation -->
    <nav class="fixed bottom-0 left-0 w-full z-50 bg-white/90 backdrop-blur-xl shadow-[0_-8px_20px_rgba(108,69,175,0.08)] rounded-t-3xl">
        <div class="flex justify-around items-center px-4 pb-6 pt-3">

            <a href="/Home/Index"
               class="flex flex-col items-center justify-center text-slate-400 hover:text-violet-700 px-5 py-2 transition">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[11px] font-semibold mt-1">HOME</span>
            </a>

            <a href="/Trips/Index"
               class="flex flex-col items-center justify-center text-slate-400 hover:text-violet-700 px-5 py-2 transition">
                <span class="material-symbols-outlined">directions_bus</span>
                <span class="text-[11px] font-semibold mt-1">TRIPS</span>
            </a>

            <a href="/Profile/Index"
               class="flex flex-col items-center justify-center bg-violet-100 text-violet-700 rounded-2xl px-5 py-2 transition">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">person</span>
                <span class="text-[11px] font-semibold mt-1">PROFILE</span>
            </a>

        </div>
    </nav>

</body>
</html>

