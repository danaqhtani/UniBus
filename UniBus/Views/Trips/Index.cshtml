@{
    ViewBag.Title = "Trips";
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Trips - UniBus</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Plus+Jakarta+Sans:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6c45af",
                        primaryContainer: "#b78efe",
                        secondary: "#b40953",
                        secondaryContainer: "#ffc2ce",
                        background: "#f6f6f8",
                        surface: "#ffffff",
                        surfaceLow: "#f0f1f3",
                        surfaceHigh: "#e1e2e5",
                        textMain: "#2d2f31",
                        textMuted: "#5a5c5d",
                        outline: "#757779",
                        outlineVariant: "#acadaf"
                    },
                    borderRadius: {
                        xl: "1.5rem",
                        full: "9999px"
                    },
                    fontFamily: {
                        headline: ["Manrope", "sans-serif"],
                        body: ["Manrope", "sans-serif"],
                        label: ["Plus Jakarta Sans", "sans-serif"]
                    }
                }
            }
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        }

        .primary-gradient {
            background: linear-gradient(135deg, #6c45af 0%, #b78efe 100%);
        }

        body {
            background-color: #f6f6f8;
            color: #2d2f31;
        }
    </style>
</head>
<body class="font-body min-h-screen bg-background text-textMain">

    <script>
        const currentBooking = {
            hasBooking: true,
            bookingId: "BK-204",
            tripId: "TR-204",
            routeName: "Route 42A",
            direction: "University → Station",
            departureTime: "09:15 AM",
            arrivalTime: "09:40 AM",
            driverName: "Marcus Thompson",
            busNumber: "BUS-0842",
            seatNumber: "12F",
            status: "Booked"
        };

        const availableTrips = [
            {
                tripId: "TR-301",
                routeName: "Route 11A",
                direction: "University → Station",
                departureTime: "07:00 AM",
                arrivalTime: "07:25 AM",
                availableSeats: 12,
                busNumber: "BUS-0810",
                driverName: "Ahmed Saleh"
            },
            {
                tripId: "TR-302",
                routeName: "Route 14A Express",
                direction: "University → Station",
                departureTime: "08:00 AM",
                arrivalTime: "08:20 AM",
                availableSeats: 5,
                busNumber: "BUS-0825",
                driverName: "Saeed Ali"
            },
            {
                tripId: "TR-401",
                routeName: "Route 18B",
                direction: "Station → University",
                departureTime: "10:00 AM",
                arrivalTime: "10:30 AM",
                availableSeats: 9,
                busNumber: "BUS-0833",
                driverName: "Nasser Omar"
            },
            {
                tripId: "TR-402",
                routeName: "Route 21C",
                direction: "Station → University",
                departureTime: "11:30 AM",
                arrivalTime: "12:00 PM",
                availableSeats: 16,
                busNumber: "BUS-0849",
                driverName: "Faisal Salem"
            }
        ];

        /*
        REAL DATABASE LATER:
        - currentBooking from dbo.Booking
        - availableTrips from dbo.ShuttleTrip
        - driverName from dbo.Driver
        - busNumber from dbo.Bus
        */
        let currentFilter = "all";
    </script>

    <!-- Top Nav -->
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-[0_12px_24px_rgba(108,69,175,0.08)]">
        <div class="flex justify-between items-center px-6 h-16 w-full max-w-7xl mx-auto">
            <div class="flex items-center gap-4">
                <a href="/Home/Index" class="p-2 hover:bg-violet-50 transition-colors rounded-full cursor-pointer">
                </a>
                <a href="/Home/Index" class="text-2xl font-black text-violet-700 font-headline tracking-tight">
                    UniBus
                </a>
              
            </div>


            <div class="p-2 rounded-full hover:bg-violet-50 transition-colors cursor-pointer">
                <span class="material-symbols-outlined text-slate-500">person</span>
            </div>
        </div>
    </nav>

    <main class="pt-24 pb-32 px-6 max-w-7xl mx-auto">

        <header class="mb-10">
            <h1 class="text-4xl font-extrabold font-headline tracking-tight mb-2">Trips</h1>
            <p class="text-textMuted font-medium">View your current booking and today’s available trips.</p>
        </header>

        <section class="mb-12">
            <div class="flex items-center justify-between mb-6 px-1">
                <h2 class="text-sm font-bold font-label uppercase tracking-widest text-slate-500">
                    Your Current Trip
                </h2>

                <div id="currentBookingBadge" class="hidden items-center gap-2 bg-pink-50 px-3 py-1 rounded-full">
                    <span class="w-2 h-2 rounded-full bg-pink-600 animate-pulse"></span>
                    <span class="text-[10px] font-bold font-label text-pink-700 uppercase">Active Booking</span>
                </div>
            </div>

            <div id="currentBookingCard" class="hidden bg-white rounded-xl p-6 md:p-8 shadow-[0_12px_24px_rgba(108,69,175,0.08)] border border-slate-200/60">
                <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
                    <div class="flex-1">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="bg-violet-100 p-3 rounded-2xl">
                                <span class="material-symbols-outlined text-violet-700 text-3xl">directions_bus</span>
                            </div>

                            <div>
                                <span id="bookingTripId" class="text-xs font-bold font-label text-slate-500 uppercase"></span>
                                <h3 id="bookingRouteName" class="text-xl font-bold font-headline text-slate-900"></h3>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="bg-slate-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Direction</p>
                                <p id="bookingDirection" class="font-bold text-slate-900"></p>
                            </div>

                            <div class="bg-slate-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Driver</p>
                                <p id="bookingDriver" class="font-bold text-slate-900"></p>
                            </div>

                            <div class="bg-slate-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Departure</p>
                                <p id="bookingDeparture" class="font-bold text-slate-900"></p>
                            </div>

                            <div class="bg-slate-50 rounded-xl p-4">
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Seat</p>
                                <p id="bookingSeat" class="font-bold text-slate-900"></p>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row lg:flex-col gap-3 lg:min-w-[220px]">
                        <a href="/Trips/Track"
                           class="primary-gradient text-white font-bold font-label py-4 px-8 rounded-xl shadow-lg shadow-violet-200 active:scale-95 transition-transform flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">near_me</span>
                            Track Trip
                        </a>

                        <button id="cancelBookingBtn"
                                class="text-pink-700 font-bold font-label py-4 px-8 rounded-xl hover:bg-pink-50 transition-colors active:scale-95">
                            Cancel Booking
                        </button>
                    </div>
                </div>
            </div>

            <div id="noBookingCard" class="hidden bg-white rounded-xl p-8 border border-slate-200/60 shadow-[0_12px_24px_rgba(108,69,175,0.05)] text-center">
                <div class="inline-flex items-center justify-center h-16 w-16 rounded-full bg-violet-100 text-violet-700 mb-4">
                    <span class="material-symbols-outlined">event_seat</span>
                </div>
                <h3 class="text-xl font-bold font-headline text-slate-900 mb-2">No booked trip yet</h3>
                <p class="text-slate-500">Choose one of the available trips below to reserve your seat.</p>
            </div>
        </section>

        <section class="mb-8">
            <div class="flex flex-wrap gap-3">
                <button class="filter-btn px-5 py-3 rounded-full bg-violet-700 text-white font-bold text-sm" data-filter="all">
                    All Trips
                </button>

                <button class="filter-btn px-5 py-3 rounded-full bg-white text-slate-700 font-bold text-sm border border-slate-200" data-filter="University → Station">
                    University → Station
                </button>

                <button class="filter-btn px-5 py-3 rounded-full bg-white text-slate-700 font-bold text-sm border border-slate-200" data-filter="Station → University">
                    Station → University
                </button>
            </div>
        </section>

        <section>
            <div class="flex items-center justify-between mb-6 px-1">
                <h2 class="text-sm font-bold font-label uppercase tracking-widest text-slate-500">
                    Available Trips Today
                </h2>
                <span id="tripCountText" class="text-sm text-slate-500 font-medium"></span>
            </div>

            <div id="tripsGrid" class="grid grid-cols-1 lg:grid-cols-2 gap-6"></div>
        </section>
    </main>

    <!-- Bottom Navigation only -->
    <nav class="fixed bottom-0 left-0 w-full z-50 bg-white/90 backdrop-blur-xl shadow-[0_-8px_20px_rgba(108,69,175,0.08)] rounded-t-3xl">
        <div class="flex justify-around items-center px-4 pb-6 pt-3">

            <a href="/Home/Index"
               class="flex flex-col items-center justify-center text-slate-400 hover:text-violet-700 px-5 py-2 transition">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[11px] font-semibold mt-1">HOME</span>
            </a>

            <a href="/Trips/Index"
               class="flex flex-col items-center justify-center bg-violet-100 text-violet-700 rounded-2xl px-5 py-2 transition">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">directions_bus</span>
                <span class="text-[11px] font-semibold mt-1">TRIPS</span>
            </a>

            <a href="/Profile/Index"
               class="flex flex-col items-center justify-center text-slate-400 hover:text-violet-700 px-5 py-2 transition">
                <span class="material-symbols-outlined">person</span>
                <span class="text-[11px] font-semibold mt-1">PROFILE</span>
            </a>

        </div>
    </nav>

    <script>
        const currentBookingCard = document.getElementById("currentBookingCard");
        const currentBookingBadge = document.getElementById("currentBookingBadge");
        const noBookingCard = document.getElementById("noBookingCard");

        function renderCurrentBooking() {
            if (currentBooking.hasBooking) {
                currentBookingCard.classList.remove("hidden");
                currentBookingBadge.classList.remove("hidden");
                currentBookingBadge.classList.add("flex");
                noBookingCard.classList.add("hidden");

                document.getElementById("bookingTripId").textContent = "Trip #" + currentBooking.tripId;
                document.getElementById("bookingRouteName").textContent = currentBooking.routeName;
                document.getElementById("bookingDirection").textContent = currentBooking.direction;
                document.getElementById("bookingDriver").textContent = currentBooking.driverName + " • " + currentBooking.busNumber;
                document.getElementById("bookingDeparture").textContent = currentBooking.departureTime + " → " + currentBooking.arrivalTime;
                document.getElementById("bookingSeat").textContent = currentBooking.seatNumber;
            } else {
                currentBookingCard.classList.add("hidden");
                currentBookingBadge.classList.add("hidden");
                noBookingCard.classList.remove("hidden");
            }
        }

        const tripsGrid = document.getElementById("tripsGrid");
        const tripCountText = document.getElementById("tripCountText");

        function buildTripCard(trip) {
            return `
                        <div class="bg-white rounded-xl p-6 md:p-7 shadow-[0_12px_24px_rgba(108,69,175,0.06)] border border-slate-200/60">
                            <div class="flex items-start justify-between gap-4 mb-5">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-widest text-violet-600 mb-2">${trip.tripId}</p>
                                    <h3 class="text-xl font-bold font-headline text-slate-900">${trip.routeName}</h3>
                                    <p class="text-slate-500 text-sm mt-1">${trip.direction}</p>
                                </div>

                                <div class="bg-violet-100 p-3 rounded-2xl">
                                    <span class="material-symbols-outlined text-violet-700">directions_bus</span>
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-4 mb-5">
                                <div class="bg-slate-50 rounded-xl p-4">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Departure</p>
                                    <p class="font-bold text-slate-900">${trip.departureTime}</p>
                                </div>

                                <div class="bg-slate-50 rounded-xl p-4">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Arrival</p>
                                    <p class="font-bold text-slate-900">${trip.arrivalTime}</p>
                                </div>

                                <div class="bg-slate-50 rounded-xl p-4">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Driver</p>
                                    <p class="font-bold text-slate-900">${trip.driverName}</p>
                                </div>

                                <div class="bg-slate-50 rounded-xl p-4">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Seats</p>
                                    <p class="font-bold text-slate-900">${trip.availableSeats} available</p>
                                </div>
                            </div>

                            <div class="flex flex-col sm:flex-row gap-3">
                                <button class="book-trip-btn primary-gradient text-white font-bold font-label py-4 px-6 rounded-xl shadow-lg shadow-violet-200 active:scale-95 transition-transform w-full"
                                        data-trip-id="${trip.tripId}">
                                    Book Trip
                                </button>

                                <button class="bg-slate-100 text-violet-700 font-bold font-label py-4 px-6 rounded-xl hover:bg-violet-100 transition-colors w-full">
                                    View Details
                                </button>
                            </div>
                        </div>
                    `;
        }

        function renderTrips() {
            let filteredTrips = availableTrips;

            if (currentFilter !== "all") {
                filteredTrips = availableTrips.filter(t => t.direction === currentFilter);
            }

            tripsGrid.innerHTML = filteredTrips.map(buildTripCard).join("");
            tripCountText.textContent = filteredTrips.length + " trip(s) found";

            attachBookHandlers();
        }

        function attachBookHandlers() {
            const bookButtons = document.querySelectorAll(".book-trip-btn");

            bookButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    const tripId = this.getAttribute("data-trip-id");
                    const selectedTrip = availableTrips.find(t => t.tripId === tripId);

                    if (!selectedTrip) return;

                    currentBooking.hasBooking = true;
                    currentBooking.tripId = selectedTrip.tripId;
                    currentBooking.routeName = selectedTrip.routeName;
                    currentBooking.direction = selectedTrip.direction;
                    currentBooking.departureTime = selectedTrip.departureTime;
                    currentBooking.arrivalTime = selectedTrip.arrivalTime;
                    currentBooking.driverName = selectedTrip.driverName;
                    currentBooking.busNumber = selectedTrip.busNumber;
                    currentBooking.seatNumber = "Auto-Assigned";

                    renderCurrentBooking();

                    window.scrollTo({
                        top: 0,
                        behavior: "smooth"
                    });
                });
            });
        }

        document.getElementById("cancelBookingBtn").addEventListener("click", function () {
            currentBooking.hasBooking = false;
            renderCurrentBooking();
        });

        const filterButtons = document.querySelectorAll(".filter-btn");

        filterButtons.forEach(button => {
            button.addEventListener("click", function () {
                currentFilter = this.getAttribute("data-filter");

                filterButtons.forEach(btn => {
                    btn.classList.remove("bg-violet-700", "text-white");
                    btn.classList.add("bg-white", "text-slate-700", "border", "border-slate-200");
                });

                this.classList.remove("bg-white", "text-slate-700", "border", "border-slate-200");
                this.classList.add("bg-violet-700", "text-white");

                renderTrips();
            });
        });

        renderCurrentBooking();
        renderTrips();
    </script>
</body>
</html>