@{
    ViewBag.Title = "Track Trip";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- =========================
         META
    ========================== -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Track Trip - UniBus</title>

    <!-- =========================
         TAILWIND
    ========================== -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- =========================
         FONTS
    ========================== -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />

    <!-- =========================
         TAILWIND CONFIG
    ========================== -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#6c45af",
                        primarySoft: "#ede9fe",
                        bgMain: "#f8f8fb",
                        textMain: "#222222",
                        textMuted: "#666666"
                    },
                    fontFamily: {
                        sans: ["Inter", "sans-serif"]
                    }
                }
            }
        };
    </script>

    <!-- =========================
         CUSTOM STYLES
    ========================== -->
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        html,
        body {
            height: 100%;
        }
    </style>
</head>

<body class="bg-bgMain text-textMain font-sans h-screen overflow-hidden">

    <!-- ==========================================================
         MOCK DATA NOW
         REAL DATA LATER FROM DATABASE
         - Booking table
         - Trip table
         - Driver table
         - Bus table
         - Algorithm result
    =========================================================== -->
    <script>
        const tripData = {
            tripStatus: "In Transit",
            etaMinutes: 5,
            routeName: "Route 42A",
            routeDirection: "To Metro Station",

            sourceName: "CCIS Building",
            destinationName: "Metro Station",

            driverName: "Marcus Thompson",
            driverPhone: "+966500000000",
            busNumber: "BUS-0842",
            busPlateNumber: "XYZ-4831",

            departureTime: "09:15 AM",
            seatNumber: "12F",

            progressPercent: 68
        };

        /*
        REAL DATA LATER EXAMPLE:

        tripData = {
            tripStatus: data.trip_status,
            etaMinutes: data.eta_minutes,
            routeName: data.route_name,
            routeDirection: data.route_direction,

            sourceName: data.source_name,
            destinationName: data.destination_name,

            driverName: data.driver_name,
            driverPhone: data.driver_phone,
            busNumber: data.bus_number,
            busPlateNumber: data.bus_plate_number,

            departureTime: data.departure_time,
            seatNumber: data.seat_number,

            progressPercent: data.progress_percent
        };
        */
    </script>

    <!-- =========================
         TOP BAR
    ========================== -->
    <header class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100">
        <div class="h-16 px-4 md:px-6 flex items-center justify-between">

            <!-- Left side -->
            <div class="flex items-center gap-3">
                <a href="/Trips/Index"
                   class="w-10 h-10 rounded-full hover:bg-violet-50 flex items-center justify-center">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>

                <span class="text-xl md:text-2xl font-extrabold text-violet-700">
                    UniBus
                </span>
            </div>

            <!-- Right side -->
           
        </div>
    </header>

    <!-- =========================
         MAIN CONTENT
    ========================== -->
    <main class="pt-16 h-full relative">

        <!-- ==========================================================
             BIG MAP AREA
             Now larger like HungerStation style
             Replace with real Google Map later
        =========================================================== -->
        <section class="absolute inset-0">

            <!-- Mock map background -->
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=1600&auto=format&fit=crop')] bg-cover bg-center"></div>
            <div class="absolute inset-0 bg-white/20"></div>

            <!-- Route drawing -->
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1000 1000" preserveAspectRatio="none">
                <!-- Full route -->
                <path d="M150,820 L360,650 L520,590 L820,250"
                      fill="none"
                      stroke="#c4b5fd"
                      stroke-width="8"
                      stroke-linecap="round" />

                <!-- Completed route -->
                <path d="M150,820 L360,650 L520,590"
                      fill="none"
                      stroke="#6c45af"
                      stroke-width="10"
                      stroke-linecap="round" />
            </svg>

            <!-- Source label -->
            <div class="absolute left-[14%] top-[78%]">
                <div class="bg-white px-3 py-1 rounded-full shadow text-xs font-bold">
                    <span id="sourceLabel">CCIS Building</span>
                </div>
            </div>

            <!-- Destination label -->
            <div class="absolute right-[10%] top-[24%]">
                <div class="bg-white px-3 py-1 rounded-full shadow text-xs font-bold">
                    <span id="destinationLabel">Metro Station</span>
                </div>
            </div>

            <!-- Bus marker -->
            <div class="absolute left-[49%] top-[57%]">
                <div class="relative">
                    <div class="absolute inset-0 rounded-full bg-violet-300 animate-ping"></div>

                    <div class="relative w-11 h-11 rounded-full bg-primary text-white flex items-center justify-center shadow-xl border-2 border-white">
                        <span class="material-symbols-outlined">directions_bus</span>
                    </div>
                </div>
            </div>

            <!-- ==========================================================
                 GOOGLE MAPS LATER

                 Replace section with:
                 <div id="map" class="absolute inset-0"></div>

                 Then add script:
                 <script async
                 src="https://maps.googleapis.com/maps/api/js?key=YOUR_KEY&callback=initMap">
                 </script>
            =========================================================== -->

        </section>

        <!-- =========================
             FLOATING TRACK CARD
        ========================== -->
        <section class="absolute bottom-20 md:bottom-6 left-1/2 -translate-x-1/2 w-[92%] sm:w-[88%] md:w-[520px] z-30">
            <div class="bg-white/95 backdrop-blur-2xl rounded-3xl shadow-2xl overflow-hidden">

                <!-- Progress bar -->
                <div class="h-1.5 bg-gray-200">
                    <div id="progressBar"
                         class="h-full bg-gradient-to-r from-violet-600 to-fuchsia-400"
                         style="width:68%">
                    </div>
                </div>

                <div class="p-4 md:p-5 space-y-4">

                    <!-- Trip status -->
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <div class="w-2 h-2 rounded-full bg-pink-600 animate-pulse"></div>

                            <p id="tripStatus"
                               class="text-xs font-bold uppercase tracking-widest text-pink-700">
                                In Transit
                            </p>
                        </div>

                        <h1 class="text-xl md:text-2xl font-extrabold">
                            Arriving in <span id="etaMinutes">5</span> min
                        </h1>

                        <p id="routeDirection" class="text-sm text-textMuted mt-1">
                            Route 42A • To Metro Station
                        </p>
                    </div>

                    <!-- Driver info -->
                    <div class="rounded-2xl bg-gray-50 p-3 flex items-center justify-between gap-3">
                        <div class="flex items-center gap-3 min-w-0">

                            <!-- Driver avatar -->
                            <div class="w-11 h-11 rounded-full bg-violet-100 text-violet-700 font-bold flex items-center justify-center shrink-0">
                                D
                            </div>

                            <!-- Driver details -->
                            <div class="min-w-0">
                                <p class="text-[10px] uppercase font-bold text-gray-400">Driver</p>

                                <p id="driverName" class="font-bold truncate">
                                    Marcus Thompson
                                </p>

                                <p id="busNumber" class="text-xs text-violet-700 font-semibold truncate">
                                    Bus: BUS-0842
                                </p>

                                <p id="plateNumber" class="text-xs text-gray-500 truncate">
                                    Plate: XYZ-4831
                                </p>
                            </div>
                        </div>

                        <!-- Call button -->
                        <a href="tel:+966500000000"
                           class="w-10 h-10 rounded-full bg-white border flex items-center justify-center hover:bg-violet-50">
                            <span class="material-symbols-outlined text-violet-700">call</span>
                        </a>
                    </div>

                    <!-- Trip details -->
                    <div class="grid grid-cols-2 gap-3">
                        <div class="bg-gray-50 rounded-2xl p-3">
                            <p class="text-[10px] uppercase font-bold text-gray-400 mb-1">Departure</p>
                            <p id="departureTime" class="font-bold">09:15 AM</p>
                        </div>

                        <div class="bg-gray-50 rounded-2xl p-3">
                            <p class="text-[10px] uppercase font-bold text-gray-400 mb-1">Seat</p>
                            <p id="seatNumber" class="font-bold">12F</p>
                        </div>
                    </div>

                    <!-- Action button -->
                    <button class="w-full h-11 rounded-2xl bg-gray-200 font-bold hover:bg-gray-300 transition">
                        Cancel Booking
                    </button>
                </div>
            </div>
        </section>
    </main>

    <!-- =========================
         BOTTOM NAV
    ========================== -->
    <nav class="fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-xl border-t border-gray-100 z-50">
        <div class="h-16 flex items-center justify-around">

            <a href="/Home/Index" class="flex flex-col items-center text-gray-400 text-xs font-semibold">
                <span class="material-symbols-outlined">home</span>
                Home
            </a>

            <a href="/Trips/Index" class="flex flex-col items-center text-violet-700 text-xs font-semibold">
                <span class="material-symbols-outlined">directions_bus</span>
                Trips
            </a>

            <a href="/Profile/Index" class="flex flex-col items-center text-gray-400 text-xs font-semibold">
                <span class="material-symbols-outlined">person</span>
                Profile
            </a>
        </div>
    </nav>

    <!-- =========================
         APPLY DATA TO UI
    ========================== -->
    <script>
        document.getElementById("tripStatus").textContent = tripData.tripStatus;
        document.getElementById("etaMinutes").textContent = tripData.etaMinutes;

        document.getElementById("routeDirection").textContent =
            tripData.routeName + " • " + tripData.routeDirection;

        document.getElementById("sourceLabel").textContent = tripData.sourceName;
        document.getElementById("destinationLabel").textContent = tripData.destinationName;

        document.getElementById("driverName").textContent = tripData.driverName;
        document.getElementById("busNumber").textContent = "Bus: " + tripData.busNumber;
        document.getElementById("plateNumber").textContent = "Plate: " + tripData.busPlateNumber;

        document.getElementById("departureTime").textContent = tripData.departureTime;
        document.getElementById("seatNumber").textContent = tripData.seatNumber;

        document.getElementById("progressBar").style.width =
            tripData.progressPercent + "%";

        /*
        ALGORITHM LATER:
        Update:
        - ETA
        - progressPercent
        - route line
        - bus position
        */
    </script>

</body>
</html>