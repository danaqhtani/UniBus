@model UniBusApp.Models.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<script>
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    primary: "#6c45af",
                    primaryContainer: "#b78efe",
                    secondary: "#b40953",
                    background: "#f6f6f8",
                    surface: "#ffffff",
                    surfaceLow: "#f0f1f3",
                    surfaceHigh: "#e1e2e5",
                    textMain: "#2d2f31",
                    textMuted: "#5a5c5d",
                    outline: "#757779",
                    outlineVariant: "#acadaf"
                },
                fontFamily: {
                    headline: ["Manrope", "sans-serif"],
                    body: ["Manrope", "sans-serif"],
                    label: ["Plus Jakarta Sans", "sans-serif"]
                },
                borderRadius: {
                    xl: "1.5rem",
                    full: "9999px"
                }
            }
        }
    }
</script>

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    body {
        background-color: #f6f6f8;
        color: #2d2f31;
    }
</style>

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-[0_12px_24px_rgba(108,69,175,0.08)]">
    <div class="flex justify-between items-center px-6 h-16 w-full max-w-7xl mx-auto">
        <div class="flex items-center gap-4">
            <a asp-controller="Student" asp-action="TodayTrips" class="text-2xl font-black text-violet-700 font-headline tracking-tight">
                UniBus
            </a>
        </div>

        <div class="flex items-center gap-3">
            <form asp-controller="Student" asp-action="Logout" method="post">
                <button type="submit"
                        class="inline-flex items-center justify-center rounded-2xl bg-rose-50 px-4 py-2 text-sm font-bold text-rose-700 hover:bg-rose-100 transition">
                    Logout
                </button>
            </form>

            <div class="h-10 w-10 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center font-bold">
                @(string.IsNullOrWhiteSpace(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
            </div>
        </div>
    </div>
</nav>

<main class="pt-24 pb-32 px-6 max-w-5xl mx-auto">
    <header class="mb-10">
        <h1 class="text-4xl font-extrabold font-headline tracking-tight mb-2">Edit Profile</h1>
        <p class="text-textMuted font-medium">Update your student account information</p>
    </header>

    <div asp-validation-summary="ModelOnly"
         class="mb-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
    </div>

    <form asp-action="EditProfile" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />

        <section class="mb-8">
            <div class="bg-white rounded-xl p-6 md:p-8 shadow-[0_12px_24px_rgba(108,69,175,0.08)] border border-slate-200/60">
                <div class="flex flex-col md:flex-row md:items-center gap-6">
                    <div class="h-24 w-24 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center text-3xl font-black shrink-0">
                        @(string.IsNullOrWhiteSpace(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                    </div>

                    <div class="flex-1">
                        <p class="text-xs font-bold font-label uppercase tracking-widest text-slate-500 mb-2">
                            Student Profile
                        </p>

                        <h2 class="text-3xl font-bold font-headline text-slate-900">
                            @Model.FullName
                        </h2>

                        <p class="text-slate-500 mt-1 break-all">
                            @Model.UniversityEmail
                        </p>
                    </div>

                    <div class="bg-slate-50 rounded-2xl px-4 py-3 min-w-[130px]">
                        <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1">
                            Student ID
                        </p>
                        <p class="font-bold text-slate-900">
                            @Model.StudentId
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <label asp-for="FullName" class="block text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">
                        Full Name
                    </label>
                    <input asp-for="FullName"
                           class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition" />
                    <span asp-validation-for="FullName" class="text-sm text-rose-600 mt-2 block"></span>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <label class="block text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">
                        University Email
                    </label>
                    <input asp-for="UniversityEmail"
                           readonly
                           class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-500 outline-none cursor-not-allowed" />
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <label asp-for="PhoneNumber" class="block text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">
                        Phone Number
                    </label>
                    <input asp-for="PhoneNumber"
                           class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition" />
                    <span asp-validation-for="PhoneNumber" class="text-sm text-rose-600 mt-2 block"></span>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                    <label asp-for="BuildingId" class="block text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2">
                        Building
                    </label>
                    <select asp-for="BuildingId"
                            asp-items="ViewBag.Buildings"
                            class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition">
                        <option value="">-- Select Building --</option>
                    </select>
                    <span asp-validation-for="BuildingId" class="text-sm text-rose-600 mt-2 block"></span>
                </div>
            </div>
        </section>

        <section class="mt-8">
            <div class="bg-white rounded-xl p-6 shadow-[0_12px_24px_rgba(108,69,175,0.05)] border border-slate-200/60">
                <div class="flex flex-wrap gap-3">
                    <button type="submit"
                            class="inline-flex items-center justify-center rounded-2xl bg-violet-600 px-6 py-3 text-sm font-bold text-white hover:bg-violet-700 transition">
                        Save Changes
                    </button>

                    <a asp-action="Profile"
                       class="inline-flex items-center justify-center rounded-2xl bg-slate-100 px-6 py-3 text-sm font-bold text-slate-700 hover:bg-slate-200 transition">
                        Cancel
                    </a>
                </div>
            </div>
        </section>
    </form>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}