@model UniBusApp.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - UniBus</title>

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#8b5cf6",
                        primarySoft: "#f3e8ff",
                        background: "#faf7fb",
                        borderSoft: "#eadcf0",
                        textMain: "#2f2f2f"
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-background flex items-center justify-center px-6">

    <div class="w-full max-w-md bg-white rounded-[32px] shadow-[0_24px_60px_rgba(0,0,0,0.08)] p-8">

        <!-- Back Button -->
        <div class="mb-6">
            <a asp-action="Login" asp-controller="Account"
               class="inline-flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-primary transition">
                ← Back
            </a>
        </div>

        <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Reset Password</h2>
        <p class="text-gray-500 mb-6 text-sm">Enter the code and your new password</p>

        @if (!ViewData.ModelState.IsValid)
        {
            @Html.ValidationSummary(false, "", new { @class = "mb-4 text-red-500 text-sm" })
        }

        <form method="post" asp-action="ResetPassword" class="space-y-5">

            <div>
                <label class="block text-sm font-semibold mb-2">Verification Code</label>
                <input asp-for="Code"
                       class="w-full h-12 rounded-xl border border-borderSoft px-4 outline-none focus:ring-2 focus:ring-purple-200" />
                <span asp-validation-for="Code" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-2">New Password</label>
                <input asp-for="NewPassword" type="password"
                       class="w-full h-12 rounded-xl border border-borderSoft px-4 outline-none focus:ring-2 focus:ring-purple-200" />
                <span asp-validation-for="NewPassword" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label class="block text-sm font-semibold mb-2">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password"
                       class="w-full h-12 rounded-xl border border-borderSoft px-4 outline-none focus:ring-2 focus:ring-purple-200" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
            </div>

            <button type="submit"
                    class="w-full h-12 rounded-xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-bold hover:opacity-95 transition">
                Reset Password
            </button>

        </form>

    </div>

</body>
</html>