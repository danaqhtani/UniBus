@{
    ViewData["Title"] = "Driver Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Driver Login - UniBus</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        driverPrimary: "#5f7f69",
                        driverSoft: "#e8f1ea",
                        driverBg: "#f6f8f5",
                        driverText: "#1f2a23",
                        driverMuted: "#6d786f"
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-driverBg flex items-center justify-center px-4">

    <div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">

        <!-- Back Button -->
        <div class="mb-6">
            <a asp-controller="Home" asp-action="Index"
               class="inline-flex items-center gap-2 text-sm font-semibold text-driverMuted hover:text-driverPrimary transition">
                <span class="material-symbols-outlined text-base">arrow_back</span>
                Back
            </a>
        </div>

        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto rounded-2xl bg-driverSoft flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-3xl text-driverPrimary">directions_bus</span>
            </div>

            <h1 class="text-4xl font-extrabold text-driverText">UniBus</h1>
        </div>

        <!-- Title -->
        <p class="text-sm uppercase tracking-widest text-driverPrimary mb-2 font-semibold">
            Driver Access
        </p>

        <h2 class="text-3xl font-extrabold mb-2 text-driverText">
            Hello again
        </h2>

        <p class="text-driverMuted mb-6">
            Enter your ID to continue
        </p>

        <!-- Error -->
        @if (ViewBag.Error != null)
        {
            <div class="mb-4 bg-red-50 border border-red-200 text-red-700 p-3 rounded-xl text-sm">
                @ViewBag.Error
            </div>
        }

        <!-- FORM  -->
        <form method="post" asp-action="Login" class="space-y-5">

            <input name="loginId"
                   type="number"
                   placeholder="Enter your ID"
                   class="w-full h-14 rounded-2xl border border-gray-300 px-4 outline-none focus:ring-2 focus:ring-driverPrimary" />

            <button type="submit"
                    class="w-full h-14 rounded-2xl bg-driverPrimary text-white font-bold hover:opacity-95 transition">
                Sign in
            </button>

        </form>

    </div>

</body>
</html>