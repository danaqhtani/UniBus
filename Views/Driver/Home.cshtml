@model IEnumerable<UniBusApp.Models.ShuttleTrip>

@{
    ViewData["Title"] = "Home";
    // for the conflect with the student layout
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />

    <style>
        body {
            font-family: 'Manrope', sans-serif;
            background-color: #f6f8f5;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400;
        }
    </style>
</head>
<body class="pb-24">

    <div class="p-6 max-w-md mx-auto">

        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-extrabold text-[#5f7f69]">UniBus</h1>
            <a href="/Driver/Logout" class="bg-red-50 text-red-600 px-4 py-2 rounded-2xl text-xs font-bold transition hover:bg-red-100">
                Logout
            </a>
        </div>

        <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Today’s trip</h2>
        <p class="text-gray-500 mb-6 text-sm">
            View your scheduled trips and open live map tracking.
        </p>

        @if (!Model.Any())
        {
            <div class="text-center text-gray-400 mt-20 py-10 bg-white rounded-[28px] border border-dashed border-gray-200">
                <span class="material-symbols-outlined text-4xl mb-2">calendar_today</span>
                <p>No trips for today</p>
            </div>
        }

        <div class="space-y-6">
            @foreach (var trip in Model)
            {
                <div class="rounded-[28px] overflow-hidden shadow-sm border border-gray-100 bg-white">
                    <div class="bg-[#dfe8e1] px-5 py-4">
                        <h3 class="text-lg font-bold text-gray-900">
                            @(trip.direction_id == 1 ? "Metro → University" : "University → Metro")
                        </h3>
                        <p class="text-[10px] uppercase tracking-widest text-gray-500 mt-1 font-bold">
                            Trip ID: TR-@trip.trip_id
                        </p>
                    </div>

                    <div class="px-5 py-5 space-y-4">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-[10px] text-gray-400 tracking-wide font-bold uppercase">Time</p>
                                <p class="text-lg font-extrabold text-gray-900">@trip.departure_time.ToString("hh:mm tt")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-[10px] text-gray-400 tracking-wide font-bold uppercase">Passengers</p>
                                <p class="text-lg font-extrabold text-gray-900">
                                    @(trip.total_seats - trip.available_seats) / @trip.total_seats
                                </p>
                            </div>
                        </div>

                        <a href="/Driver/Tracking?tripId=@trip.trip_id"
                           class="block w-full text-center bg-[#e3ebe4] text-[#5f7f69] py-3 rounded-2xl font-bold text-sm hover:bg-[#d8e2da] transition">
                            View Trip
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
    <nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-xl border-t border-gray-100 z-50">
        <div class="h-16 flex items-center justify-around max-w-lg mx-auto">

            <a href="/Driver/Home" class="flex flex-col items-center text-[#6d786f] group">
               
                <span class="material-symbols-outlined text-2xl">home</span>
                <span class="text-[11px] font-semibold mt-1">Home</span>
            </a>

            <a href="/Driver/Profile" class="flex flex-col items-center text-[#5f7f69]">
                
                <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1">person</span>
                <span class="text-[11px] font-semibold mt-1">Profile</span>
            </a>

        </div>
    </nav>

</body>
</html>